# Wolf Pack Backend Environment Variables
# Copy to .env and fill with your values

# Server
PORT=3001
NODE_ENV=production

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/wolfpack
# For Render: use DATABASE_URL from Render dashboard

# Security
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_BotFather
TELEGRAM_BOT_USERNAME=wolfpackgame_bot

# TON Blockchain
TON_API_KEY=your_ton_api_key_optional
TON_NETWORK=testnet # or mainnet
TON_WALLET_ADDRESS=your_wallet_address_for_deposits

# Game Configuration
GAME_TOKEN_NAME=WPK
GAME_TOKEN_DECIMALS=6
INITIAL_TOKEN_SUPPLY=1000000000

# Referral Program
REFERRAL_LEVEL1_PERCENT=25
REFERRAL_LEVEL2_PERCENT=15
REFERRAL_LEVEL3_PERCENT=5

# Deposit Configuration
MIN_DEPOSIT_TON=1
DEPOSIT_FEE_PERCENT=0

# Admin
ADMIN_TELEGRAM_ID=your_admin_telegram_id